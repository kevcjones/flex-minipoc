{
  "name": "flex-minipoc",
  "version": "0.1.0",
  "private": true,
  "bin": { "flex-minipoc": "bin/app.ts" },
  "scripts": {
    "synth": "cdk synth",
    "deploy": "cdk deploy --all --require-approval never",
    "prune": "ts-node scripts/prune.ts",
    "prune:dry": "ts-node scripts/prune.ts --dry-run",
    "deploy:sync": "cdk deploy --all --require-approval never && ts-node scripts/prune.ts",
    "destroy": "cdk destroy --all"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "aws-cdk": "^2.160.0",
    "esbuild": "^0.23.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.160.0",
    "constructs": "^10.3.0",
    "source-map-support": "^0.5.21"
  }
}

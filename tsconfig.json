{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": { "@flex/sdk/*": ["core/*/sdk"] },
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": [
    "bin/**/*.ts",
    "platform/**/*.ts",
    "core/**/stack.ts",
    "core/**/sdk.ts",
    "config.ts"
  ],
  "exclude": ["node_modules", "cdk.out"]
}
